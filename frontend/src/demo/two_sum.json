{"key": "two_sum", "label": "Two Sum (hash map)", "code": "def two_sum(nums, target):\n    seen = {}\n    for i, num in enumerate(nums):\n        complement = target - num\n        if complement in seen:\n            return [seen[complement], i]\n        seen[num] = i\n    return []\n", "functionName": "two_sum", "argsText": "[[2, 7, 11, 15], 9]", "timeline": [{"step": 0, "line_number": 2, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9}}, {"step": 1, "line_number": 3, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {}}}, {"step": 2, "line_number": 4, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {}, "i": 0, "num": 2}}, {"step": 3, "line_number": 5, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {}, "i": 0, "num": 2, "complement": 7}}, {"step": 4, "line_number": 7, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {}, "i": 0, "num": 2, "complement": 7}}, {"step": 5, "line_number": 3, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {"2": 0}, "i": 0, "num": 2, "complement": 7}}, {"step": 6, "line_number": 4, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {"2": 0}, "i": 1, "num": 7, "complement": 7}}, {"step": 7, "line_number": 5, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {"2": 0}, "i": 1, "num": 7, "complement": 2}}, {"step": 8, "line_number": 6, "frame_name": "two_sum", "local_variables": {"nums": [2, 7, 11, 15], "target": 9, "seen": {"2": 0}, "i": 1, "num": 7, "complement": 2}}]}